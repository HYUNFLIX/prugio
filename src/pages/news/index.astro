---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const articles = [
  {
    id: 1,
    date: '2025.12.09',
    category: '공지',
    categoryColor: 'bg-navy-100 text-navy-700',
    title: '동래 푸르지오 에듀포레 분양 일정 최종 안내',
    summary: '입주자 모집 공고 일정 및 청약 접수 일정이 확정되었습니다. 청약 신청 전 반드시 확인하세요.',
    views: 2840,
  },
  {
    id: 2,
    date: '2025.11.28',
    category: '뉴스',
    categoryColor: 'bg-green-100 text-green-700',
    title: '동래구 신규 분양 시장 분석 - 왜 지금 에듀포레인가',
    summary: '부산 동래구 아파트 시장 동향과 에듀포레의 입지적 강점을 심층 분석합니다.',
    views: 1923,
  },
  {
    id: 3,
    date: '2025.11.15',
    category: '공지',
    categoryColor: 'bg-navy-100 text-navy-700',
    title: '사전 청약 접수 및 상담센터 운영 일정 안내',
    summary: '상담센터 위치, 운영 시간, 방문 예약 방법을 안내드립니다.',
    views: 3102,
  },
  {
    id: 4,
    date: '2025.10.30',
    category: '뉴스',
    categoryColor: 'bg-green-100 text-green-700',
    title: '동래 교육환경 분석 - 전국 상위 1% 학군',
    summary: '동래구 내 우수 학교 현황과 학군 프리미엄이 아파트 가치에 미치는 영향을 분석합니다.',
    views: 4215,
  },
  {
    id: 5,
    date: '2025.10.15',
    category: '뉴스',
    categoryColor: 'bg-green-100 text-green-700',
    title: '금강공원·온천천 인접 - 자연환경이 주는 삶의 가치',
    summary: '도시 속 자연환경이 주거 만족도와 부동산 가치에 미치는 영향을 살펴봅니다.',
    views: 1547,
  },
  {
    id: 6,
    date: '2025.09.28',
    category: '공지',
    categoryColor: 'bg-navy-100 text-navy-700',
    title: '동래 푸르지오 에듀포레 분양 홍보관 오픈 안내',
    summary: '홍보관이 오픈되었습니다. 분양 홍보관을 방문하여 직접 모델하우스를 체험해보세요.',
    views: 5831,
  },
];
---

<Layout title="뉴스/공지" description="동래 푸르지오 에듀포레 최신 뉴스와 공지사항">
  <Header />

  <div class="bg-navy-950 text-white py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-gold-400 text-sm font-semibold tracking-widest uppercase mb-3">News & Notice</p>
      <h1 class="text-4xl font-black">뉴스 / 공지</h1>
    </div>
  </div>

  <section class="bg-gray-50 py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="space-y-4">
        {articles.map(a => (
          <a
            href={`/news/${a.id}`}
            class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 flex gap-5 hover:shadow-md hover:border-navy-200 transition-all group block"
          >
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-3 mb-3">
                <span class={`text-xs font-bold px-2.5 py-1 rounded flex-shrink-0 ${a.categoryColor}`}>
                  {a.category}
                </span>
                <span class="text-gray-400 text-sm">{a.date}</span>
              </div>
              <h2 class="text-gray-800 font-bold text-lg group-hover:text-navy-700 transition-colors mb-2 line-clamp-1">
                {a.title}
              </h2>
              <p class="text-gray-500 text-sm line-clamp-2">{a.summary}</p>
            </div>
            <div class="flex-shrink-0 flex flex-col items-end justify-between">
              <span class="text-gray-400 group-hover:text-navy-700 transition-colors text-xl">→</span>
              <span class="text-gray-400 text-xs">조회 {a.views.toLocaleString()}</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <Footer />
</Layout>
