---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const unitTypes = [
  { type: '74㎡A', area: '74.98㎡', rooms: '방3 욕실2', tag: '타입A' },
  { type: '76㎡A', area: '76.47㎡', rooms: '방3 욕실2', tag: '타입A' },
  { type: '84㎡A', area: '84.97㎡', rooms: '방3 욕실2', tag: '대표타입' },
  { type: '84㎡A1', area: '84.97㎡', rooms: '방3 욕실2', tag: '특화타입' },
];

const premiumFeatures = [
  {
    label: 'EDUCATION',
    title: '명문 학군',
    items: ['충렬초·중·고 도보권', '혜화초·여중·여고 도보권', '동래구 최고 교육환경'],
    icon: '🎓',
  },
  {
    label: 'TRAFFIC',
    title: '편리한 교통',
    items: ['원동IC 인근', '동해남부선 역세권', '부산 도심 빠른 접근'],
    icon: '🚇',
  },
  {
    label: 'NATURE',
    title: '자연환경',
    items: ['온천천 산책로', '수영강 수변공원', '명장공원 인접'],
    icon: '🌿',
  },
  {
    label: 'CONVENIENCE',
    title: '생활편의',
    items: ['이마트 트레이더스', '코스트코', '동래봉생병원'],
    icon: '🏪',
  },
];

const news = [
  { date: '2026.03.05', category: '공지', title: '동래 푸르지오 에듀포레 선착순 동·호 지정계약 진행 중' },
  { date: '2026.02.20', category: '뉴스', title: '동래구 랜드마크 대단지 1,481세대 분양 완판 임박' },
  { date: '2026.01.15', category: '공지', title: '관심고객 사전 등록 혜택 안내' },
  { date: '2025.12.10', category: '뉴스', title: '대우건설 시공 프리미엄 브랜드 에듀포레 특장점 분석' },
];
---

<Layout title="홈">
  <Header />

  <!-- ─── SECTION 1: HERO ──────────────────────────────────── -->
  <section id="hero" class="relative min-h-screen flex items-center justify-center overflow-hidden" style="background: linear-gradient(160deg, #0e1a14 0%, #1b493c 50%, #112d22 100%);">
    <!-- 배경 장식 -->
    <div class="absolute inset-0">
      <div class="absolute inset-0 opacity-20" style="background: radial-gradient(ellipse at 30% 50%, #2d7a5f 0%, transparent 60%), radial-gradient(ellipse at 80% 20%, #154734 0%, transparent 50%);"></div>
      <!-- 격자 패턴 -->
      <div class="absolute inset-0 opacity-5" style="background-image: linear-gradient(#fff 1px, transparent 1px), linear-gradient(90deg, #fff 1px, transparent 1px); background-size: 60px 60px;"></div>
    </div>

    <div class="relative z-10 max-w-7xl mx-auto px-6 md:px-10 py-32 w-full">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <!-- 텍스트 -->
        <div>
          <!-- 상태 뱃지 -->
          <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full mb-8 border text-sm font-medium" style="border-color: rgba(214,180,107,0.5); color: #d6b46b; background: rgba(214,180,107,0.1);">
            <span class="w-2 h-2 rounded-full animate-pulse" style="background:#d6b46b;"></span>
            선착순 동·호 지정계약 진행 중
          </div>

          <!-- 메인 타이틀 -->
          <h1 class="text-white mb-3" style="font-size: clamp(2.5rem, 5vw, 4rem); font-weight: 900; line-height: 1.1; letter-spacing: -0.02em;">
            동래를 새롭게<br/>
            대표하는<br/>
            <span style="color:#d6b46b;">프리미엄 대단지</span>
          </h1>

          <p class="text-2xl font-light tracking-widest mb-8" style="color: rgba(255,255,255,0.7); letter-spacing: 0.15em;">
            동래 푸르지오 에듀포레
          </p>

          <p class="text-base leading-relaxed mb-10" style="color: rgba(255,255,255,0.6);">
            부산 동래구 안락동 | 전용 74~84㎡ | 총 1,481세대<br/>
            시공: (주)대우건설 | 시행: 안락1구역주택재건축정비사업조합
          </p>

          <div class="flex flex-col sm:flex-row gap-4">
            <a href="#contact" class="flex items-center justify-center gap-2 px-8 py-4 rounded text-white font-bold text-base transition-all hover:opacity-90" style="background:#1b493c; border:1px solid #2d7a5f;">
              관심고객 등록하기 →
            </a>
            <a href="tel:16665326" class="flex items-center justify-center gap-2 px-8 py-4 rounded font-bold text-base transition-all" style="background: rgba(255,255,255,0.08); border:1px solid rgba(255,255,255,0.2); color:white;">
              📞 1666-5326
            </a>
          </div>
        </div>

        <!-- 정보 카드 -->
        <div class="space-y-4">
          <!-- 메인 스탯 카드 -->
          <div class="rounded-2xl p-8" style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); backdrop-filter: blur(10px);">
            <div class="grid grid-cols-3 gap-6 text-center">
              <div>
                <p class="text-xs tracking-widest mb-2" style="color: rgba(255,255,255,0.5);">총 세대수</p>
                <p class="text-3xl font-black text-white">1,481</p>
                <p class="text-xs mt-1" style="color: rgba(255,255,255,0.4);">세대</p>
              </div>
              <div class="border-x" style="border-color: rgba(255,255,255,0.1);">
                <p class="text-xs tracking-widest mb-2" style="color: rgba(255,255,255,0.5);">최고층수</p>
                <p class="text-3xl font-black" style="color:#d6b46b;">29F</p>
                <p class="text-xs mt-1" style="color: rgba(255,255,255,0.4);">최고</p>
              </div>
              <div>
                <p class="text-xs tracking-widest mb-2" style="color: rgba(255,255,255,0.5);">입주예정</p>
                <p class="text-3xl font-black text-white">2028</p>
                <p class="text-xs mt-1" style="color: rgba(255,255,255,0.4);">예정</p>
              </div>
            </div>
          </div>

          <!-- 평형 미리보기 -->
          <div class="grid grid-cols-2 gap-3">
            {unitTypes.map(u => (
              <div class="rounded-xl p-5" style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08);">
                <p class="text-xs mb-2" style="color: #d6b46b; font-weight:600;">{u.tag}</p>
                <p class="text-white text-xl font-black">{u.type}</p>
                <p class="text-sm mt-1" style="color: rgba(255,255,255,0.5);">{u.rooms}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>

    <!-- 스크롤 인디케이터 -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 animate-bounce">
      <p class="text-xs tracking-widest" style="color: rgba(255,255,255,0.4);">SCROLL</p>
      <div class="w-px h-8" style="background: linear-gradient(to bottom, rgba(255,255,255,0.4), transparent);"></div>
    </div>
  </section>

  <!-- ─── SECTION 2: UNIT PLAN ──────────────────────────────── -->
  <section id="floorplan" class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-6 md:px-10">
      <!-- 섹션 헤더 -->
      <div class="text-center mb-16">
        <p class="text-xs tracking-widest font-semibold mb-3 uppercase" style="color:#1b493c; letter-spacing: 0.3em;">UNIT PLAN</p>
        <h2 class="text-4xl md:text-5xl font-black" style="color:#112d22; letter-spacing: -0.02em;">평 형 안 내</h2>
        <div class="w-12 h-0.5 mx-auto mt-4" style="background:#1b493c;"></div>
      </div>

      <!-- 평형 카드 그리드 -->
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {unitTypes.map((u, i) => (
          <div class="group rounded-2xl overflow-hidden transition-all duration-300 hover:shadow-2xl hover:-translate-y-2" style="border: 1px solid #e8e4df;">
            <!-- 상단 색상 바 -->
            <div class="h-1.5" style={`background: ${i === 2 ? '#1b493c' : '#154734'};`}></div>
            <div class="p-7">
              <!-- 타입 배지 -->
              <div class="flex items-start justify-between mb-5">
                <div>
                  <p class="text-xs font-semibold tracking-wider mb-1" style="color:#6d5b51;">{u.tag}</p>
                  <p class="text-3xl font-black" style="color:#1b493c;">{u.type}</p>
                </div>
                {i === 2 && (
                  <span class="px-3 py-1 rounded-full text-xs font-bold text-white" style="background:#1b493c;">대표</span>
                )}
              </div>

              <!-- 스펙 -->
              <div class="space-y-3 mb-6">
                <div class="flex justify-between items-center py-2 border-b" style="border-color:#f0ece8;">
                  <span class="text-sm" style="color:#888;">전용면적</span>
                  <span class="text-sm font-semibold" style="color:#333;">{u.area}</span>
                </div>
                <div class="flex justify-between items-center py-2 border-b" style="border-color:#f0ece8;">
                  <span class="text-sm" style="color:#888;">구조</span>
                  <span class="text-sm font-semibold" style="color:#333;">{u.rooms}</span>
                </div>
              </div>

              <!-- 평면도 영역 (플레이스홀더) -->
              <div class="rounded-xl flex items-center justify-center h-36 mb-5" style="background:#f7f4f0;">
                <span class="text-sm font-medium" style="color:#6d5b51;">평면도 이미지</span>
              </div>

              <a href="#contact" class="block text-center py-3 rounded-lg text-sm font-semibold transition-all" style="background:#1b493c; color:white;">
                상세 문의 →
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── SECTION 3: LANDSCAPE ──────────────────────────────── -->
  <section id="complex" class="py-24" style="background:#f5f1ec;">
    <div class="max-w-7xl mx-auto px-6 md:px-10">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <!-- 텍스트 -->
        <div>
          <p class="text-xs tracking-widest font-semibold mb-3 uppercase" style="color:#1b493c; letter-spacing: 0.3em;">LANDSCAPE</p>
          <h2 class="text-4xl md:text-5xl font-black mb-6" style="color:#112d22; letter-spacing: -0.02em; line-height: 1.15;">
            자연이 함께하는<br/>
            <span style="color:#1b493c;">프리미엄 조경</span>
          </h2>
          <p class="text-base leading-relaxed mb-8" style="color:#555;">
            1,481세대 대단지의 규모를 살린 광활한 커뮤니티 조경 공간.
            온천천과 수영강을 품은 자연 속에서, 도심의 편리함과
            자연의 여유로움을 동시에 누리실 수 있습니다.
          </p>
          <div class="grid grid-cols-2 gap-4">
            {[
              { label: '커뮤니티 시설', value: '20+ 종류' },
              { label: '조경 면적', value: '대규모' },
              { label: '단지 내 산책로', value: '다수' },
              { label: '어린이 놀이터', value: '테마형' },
            ].map(item => (
              <div class="rounded-xl p-4" style="background:white; border:1px solid #e0d8cf;">
                <p class="text-xs mb-1" style="color:#888;">{item.label}</p>
                <p class="text-base font-bold" style="color:#1b493c;">{item.value}</p>
              </div>
            ))}
          </div>
        </div>

        <!-- 이미지 플레이스홀더 -->
        <div class="rounded-2xl overflow-hidden shadow-2xl flex items-center justify-center" style="background: linear-gradient(135deg, #1b493c, #2d7a5f); height:400px;">
          <div class="text-center text-white/60">
            <div class="text-6xl mb-4">🌿</div>
            <p class="text-lg font-light tracking-wider">조경 이미지</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── SECTION 4: GREENERY LOUNGE ───────────────────────── -->
  <section id="greenery" class="py-24 text-white" style="background: linear-gradient(135deg, #112d22 0%, #1b493c 100%);">
    <div class="max-w-7xl mx-auto px-6 md:px-10">
      <div class="text-center mb-16">
        <p class="text-xs tracking-widest font-semibold mb-3 uppercase" style="color:#d6b46b; letter-spacing: 0.3em;">GREENERY LOUNGE</p>
        <h2 class="text-4xl md:text-5xl font-black mb-4" style="letter-spacing: -0.02em;">그리너리 라운지</h2>
        <p class="text-lg font-light" style="color: rgba(255,255,255,0.6);">자연과 함께하는 프리미엄 커뮤니티</p>
        <div class="w-12 h-0.5 mx-auto mt-4" style="background:#d6b46b;"></div>
      </div>

      <!-- 커뮤니티 시설 그리드 -->
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-5">
        {[
          { icon: '🏊', name: '수영장' },
          { icon: '🏋️', name: '피트니스' },
          { icon: '🧖', name: '스파' },
          { icon: '📚', name: '도서관' },
          { icon: '🎭', name: '문화센터' },
          { icon: '🍳', name: '게스트하우스' },
          { icon: '🎮', name: '키즈카페' },
          { icon: '🌳', name: '루프탑가든' },
        ].map(item => (
          <div class="rounded-2xl p-6 text-center transition-all hover:scale-105 cursor-default" style="background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1);">
            <div class="text-4xl mb-3">{item.icon}</div>
            <p class="font-semibold tracking-wide text-sm" style="color: rgba(255,255,255,0.9);">{item.name}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── SECTION 5: PREMIUM VISION ────────────────────────── -->
  <section id="premium" class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-6 md:px-10">
      <!-- 섹션 헤더 -->
      <div class="text-center mb-16">
        <p class="text-xs tracking-widest font-semibold mb-3 uppercase" style="color:#1b493c; letter-spacing: 0.3em;">PREMIUM VISION</p>
        <h2 class="text-4xl md:text-5xl font-black mb-4" style="color:#112d22; letter-spacing: -0.02em;">
          1,481세대 랜드마크<br/>
          <span style="color:#1b493c;">프리미엄 입지</span>
        </h2>
        <p class="text-lg" style="color:#555;">동래구를 새롭게 대표하는 프리미엄 입지 4가지</p>
        <div class="w-12 h-0.5 mx-auto mt-4" style="background:#1b493c;"></div>
      </div>

      <!-- 4개 입지 카드 -->
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        {premiumFeatures.map((f, i) => (
          <div class="group rounded-2xl overflow-hidden transition-all duration-300 hover:shadow-2xl hover:-translate-y-2" style="border: 1px solid #e8e4df;">
            <!-- 상단 헤더 -->
            <div class="px-6 py-5" style={`background: ${i % 2 === 0 ? '#1b493c' : '#154734'};`}>
              <p class="text-xs font-bold tracking-widest mb-1 opacity-70" style="color: rgba(255,255,255,0.7);">{f.label}</p>
              <h3 class="text-xl font-black text-white">{f.title}</h3>
            </div>
            <!-- 내용 -->
            <div class="p-6">
              <div class="text-4xl mb-4">{f.icon}</div>
              <ul class="space-y-2">
                {f.items.map(item => (
                  <li class="flex items-start gap-2 text-sm" style="color:#555;">
                    <span class="flex-shrink-0 w-4 h-4 rounded-full flex items-center justify-center mt-0.5 text-xs" style="background:#1b493c; color:white;">✓</span>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── SECTION 6: 분양 일정 ──────────────────────────────── -->
  <section id="schedule" class="py-20" style="background:#f5f1ec;">
    <div class="max-w-7xl mx-auto px-6 md:px-10">
      <div class="text-center mb-12">
        <p class="text-xs tracking-widest font-semibold mb-3 uppercase" style="color:#1b493c; letter-spacing: 0.3em;">SCHEDULE</p>
        <h2 class="text-3xl md:text-4xl font-black" style="color:#112d22;">분양 일정</h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-3 lg:grid-cols-5 gap-4">
        {[
          { step: '01', label: '사전 홍보', date: '2025.10~', done: true },
          { step: '02', label: '입주자모집 공고', date: '2025.12', done: true },
          { step: '03', label: '청약 접수', date: '2026.01~02', done: true },
          { step: '04', label: '당첨자 발표', date: '2026.02', done: true },
          { step: '05', label: '계약 진행', date: '2026.03 ~', done: false, current: true },
        ].map(s => (
          <div class={`rounded-xl p-5 border-2 transition-all`} style={s.current ? 'border-color:#1b493c; background:#f0f9f4;' : s.done ? 'border-color:#c8d8c4; background:white;' : 'border-color:#e0e0e0; background:white;'}>
            <div class="flex items-center gap-2 mb-2">
              <span class="text-xs font-bold" style={`color: ${s.current ? '#1b493c' : s.done ? '#2d7a5f' : '#aaa'};`}>STEP {s.step}</span>
              {s.current && <span class="px-2 py-0.5 rounded-full text-xs font-bold text-white" style="background:#1b493c;">진행중</span>}
              {s.done && !s.current && <span class="text-xs" style="color:#2d7a5f;">✓</span>}
            </div>
            <p class="font-bold text-sm" style="color:#1b1b1b;">{s.label}</p>
            <p class="text-xs mt-1" style={`color: ${s.current ? '#1b493c' : '#888'};`}>{s.date}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── SECTION 7: 뉴스/공지 ─────────────────────────────── -->
  <section id="news" class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-6 md:px-10">
      <div class="flex items-end justify-between mb-10">
        <div>
          <p class="text-xs tracking-widest font-semibold mb-2 uppercase" style="color:#1b493c; letter-spacing: 0.3em;">NEWS & NOTICE</p>
          <h2 class="text-3xl font-black" style="color:#112d22;">뉴스 / 공지</h2>
        </div>
        <a href="/news" class="text-sm font-semibold transition-colors" style="color:#1b493c;">
          전체보기 →
        </a>
      </div>

      <div class="divide-y" style="border-color:#f0ece8;">
        {news.map(n => (
          <a href="/news" class="flex items-center gap-6 py-5 -mx-4 px-4 rounded-lg transition-colors hover:bg-gray-50 group">
            <span class="text-xs font-bold px-3 py-1 rounded-full flex-shrink-0" style={n.category === '공지' ? 'background:#e8f5f0; color:#1b493c;' : 'background:#f5f1ec; color:#6d5b51;'}>
              {n.category}
            </span>
            <span class="text-sm font-medium flex-1 group-hover:text-[#1b493c] transition-colors" style="color:#333;">
              {n.title}
            </span>
            <span class="text-xs flex-shrink-0" style="color:#aaa;">{n.date}</span>
            <span class="flex-shrink-0 transition-transform group-hover:translate-x-1" style="color:#1b493c;">→</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── SECTION 8: CTA ───────────────────────────────────── -->
  <section id="contact" class="py-20 text-white" style="background: linear-gradient(135deg, #112d22, #1b493c);">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <p class="text-xs tracking-widest font-semibold mb-4 uppercase" style="color:#d6b46b; letter-spacing: 0.3em;">CONTACT</p>
      <h2 class="text-4xl md:text-5xl font-black mb-4" style="line-height:1.2;">
        관심고객 등록하기
      </h2>
      <p class="text-lg font-light mb-10" style="color: rgba(255,255,255,0.65);">
