---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="문의하기" description="동래 푸르지오 에듀포레 분양 문의 및 상담 신청">
  <Header />

  <div class="bg-navy-950 text-white py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-gold-400 text-sm font-semibold tracking-widest uppercase mb-3">Contact</p>
      <h1 class="text-4xl font-black">문의하기</h1>
      <p class="text-gray-400 mt-3">전문 상담사가 맞춤형 분양 정보를 제공해 드립니다</p>
    </div>
  </div>

  <section class="bg-gray-50 py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-3 gap-10">

        <!-- 연락처 정보 -->
        <div class="lg:col-span-1 space-y-6">
          <div class="bg-navy-900 text-white rounded-2xl p-6">
            <h3 class="font-bold text-lg mb-4 text-gold-400">분양 상담 센터</h3>
            <div class="space-y-4">
              <div>
                <p class="text-gray-400 text-xs mb-1">전화</p>
                <p class="text-2xl font-black">1588-0000</p>
              </div>
              <div>
                <p class="text-gray-400 text-xs mb-1">운영 시간</p>
                <p class="text-sm">평일 09:00 ~ 18:00</p>
                <p class="text-sm">주말/공휴일 10:00 ~ 17:00</p>
              </div>
              <div>
                <p class="text-gray-400 text-xs mb-1">상담센터 위치</p>
                <p class="text-sm">부산광역시 동래구 명륜동<br/>동래 푸르지오 에듀포레 분양 홍보관</p>
              </div>
            </div>
            <a
              href="tel:1588-0000"
              class="mt-5 block text-center bg-gold-400 hover:bg-gold-500 text-navy-950 font-bold py-3 rounded-lg transition-colors"
            >
              📞 바로 전화하기
            </a>
          </div>

          <div class="bg-white rounded-2xl border border-gray-100 p-6">
            <h3 class="font-bold text-navy-900 mb-4">오시는 길</h3>
            <div class="bg-gray-100 rounded-lg h-40 flex items-center justify-center text-gray-400 text-sm mb-4">
              🗺️ 지도 영역 (Google Maps 삽입 예정)
            </div>
            <p class="text-sm text-gray-600">
              <strong>지하철:</strong> 4호선 수안역 3번 출구 도보 5분<br/>
              <strong>버스:</strong> 동래역 하차 도보 10분<br/>
              <strong>주차:</strong> 홍보관 내 무료 주차 가능
            </p>
          </div>
        </div>

        <!-- 온라인 상담 폼 -->
        <div class="lg:col-span-2">
          <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-8">
            <h2 class="text-2xl font-black text-navy-900 mb-2">온라인 상담 신청</h2>
            <p class="text-gray-500 text-sm mb-8">입력하신 정보로 24시간 이내 연락드리겠습니다.</p>

            <!-- Formspree 폼 (YOUR_FORM_ID를 실제 Formspree ID로 교체하세요) -->
            <form action="https://formspree.io/f/YOUR_FORM_ID" method="POST" class="space-y-5">

              <div class="grid sm:grid-cols-2 gap-5">
                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-1.5">이름 <span class="text-red-500">*</span></label>
                  <input
                    type="text"
                    name="name"
                    required
                    placeholder="홍길동"
                    class="w-full border border-gray-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-navy-500 focus:border-transparent transition"
                  />
                </div>
                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-1.5">연락처 <span class="text-red-500">*</span></label>
                  <input
                    type="tel"
                    name="phone"
                    required
                    placeholder="010-0000-0000"
                    class="w-full border border-gray-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-navy-500 focus:border-transparent transition"
                  />
                </div>
              </div>

              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1.5">이메일</label>
                <input
                  type="email"
                  name="email"
                  placeholder="example@email.com"
                  class="w-full border border-gray-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-navy-500 focus:border-transparent transition"
                />
              </div>

              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1.5">관심 평형</label>
                <select
                  name="unit_type"
                  class="w-full border border-gray-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-navy-500 focus:border-transparent transition"
                >
                  <option value="">선택해주세요</option>
                  <option value="59A">59A (전용 59㎡)</option>
                  <option value="74B">74B (전용 74㎡)</option>
                  <option value="84C">84C (전용 84㎡) - 대표 평형</option>
                  <option value="99A">99A (전용 99㎡) - 프리미엄</option>
                  <option value="미정">미정 (상담 후 결정)</option>
                </select>
              </div>

              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1.5">상담 가능 시간</label>
                <select
                  name="preferred_time"
                  class="w-full border border-gray-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-navy-500 focus:border-transparent transition"
                >
                  <option value="">선택해주세요</option>
                  <option value="오전 (09:00~12:00)">오전 (09:00~12:00)</option>
                  <option value="오후 (13:00~18:00)">오후 (13:00~18:00)</option>
                  <option value="저녁 (18:00~21:00)">저녁 (18:00~21:00)</option>
                  <option value="주말">주말</option>
                </select>
              </div>

              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1.5">문의 내용</label>
                <textarea
                  name="message"
                  rows="4"
                  placeholder="분양 관련 궁금한 사항을 자유롭게 작성해 주세요."
                  class="w-full border border-gray-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-navy-500 focus:border-transparent transition resize-none"
                ></textarea>
              </div>

              <div class="flex items-start gap-3">
                <input type="checkbox" id="privacy" name="privacy" required class="mt-0.5 w-4 h-4 accent-navy-700" />
                <label for="privacy" class="text-sm text-gray-600">
                  <span class="text-red-500">*</span> 개인정보 수집 및 이용에 동의합니다.
                  수집된 정보는 분양 상담 목적으로만 사용되며, 상담 완료 후 즉시 파기됩니다.
                </label>
              </div>

              <button
                type="submit"
                class="w-full bg-navy-900 hover:bg-navy-700 text-white font-bold text-lg py-4 rounded-lg transition-all hover:scale-[1.01] shadow-md"
              >
                상담 신청하기 →
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
